# GitHub OAuth App 설정
# GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
#
#   Homepage URL:              http://localhost:5173
#   Authorization callback URL: http://localhost:5173
#
# 발급받은 값을 아래에 입력 후 파일명을 .env 로 변경하세요

VITE_GITHUB_CLIENT_ID=여기에_Client_ID_입력
GITHUB_CLIENT_SECRET=여기에_Client_secret_입력

# API 서버(server/index.ts)
PORT=8787
# 쉼표로 여러 GitHub 로그인 허용 (관리자 전역 설정 PUT /api/admin/global)
ADMIN_GITHUB_LOGINS=rjsgud49
# 프론트에서 관리자 버튼 표시 (VITE_ 만 브라우저에 노출됨)
VITE_ADMIN_GITHUB_LOGINS=rjsgud49

# 프론트만 다른 URL에 올릴 때(예: 정적 사이트 + API 서버 분리): API 베이스 (끝 슬래시 없음)
# 설정 시 /api 요청과 /사진 이미지가 모두 이 호스트로 갑니다.
# VITE_API_BASE_URL=http://127.0.0.1:8787

# API 서버 전용 — HTML이 다른 호스트에서 열릴 때 브라우저가 /api·/사진을 찍을 절대 URL.
# 비우면 /api/health 이 요청의 Host·X-Forwarded-* 로 자동 추론합니다(0.0.0.0은 사용 불가).
# PUBLIC_API_ORIGIN=http://공인IP:8787

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=여기에_MySQL_비밀번호
DB_NAME=gacha
