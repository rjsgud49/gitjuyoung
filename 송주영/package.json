{
  "name": "gacha-collector",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -n api,vite -c blue,green \"npm run server:dev\" \"vite\"",
    "server": "tsx server/index.ts",
    "server:dev": "tsx watch server/index.ts",
    "sync-photos": "node -e \"const fs=require('fs');const src='사진';const dst='public/사진';fs.readdirSync(src).forEach(f=>{const d=dst+'/'+f;if(!fs.existsSync(d)){fs.copyFileSync(src+'/'+f,d);console.log('copied:',f)}});\"",
    "build": "npm run sync-photos && tsc -b && vite build",
    "start": "npm run build && npm run server",
    "db:init": "tsx server/init-db.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mysql2": "^3.11.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
